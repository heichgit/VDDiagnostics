OPENAI_API_KEY=sk-...

# JWT (obligatorio con autenticación). En Azure: Application settings → JWT_SECRET
# Sin comillas; al pegar en el portal, evitá espacio o salto de línea antes/después (si no, falla /api/auth/me).
JWT_SECRET=cambiar-por-secreto-largo-y-aleatorio
# Opcional: expiración del token (ej. 12h, 7d)
# JWT_EXPIRES_IN=12h

# Primer usuario admin si data/users.json está vacío (solo local / primer arranque)
INITIAL_ADMIN_EMAIL=admin@ejemplo.com
INITIAL_ADMIN_PASSWORD=cambiar-en-produccion

# Duración máxima de grabación para Whisper (minutos). La app lee GET /api/config.
# Local (Express): MAX_RECORDING_MINUTES
# MAX_RECORDING_MINUTES=5
# Si no definís MAX_RECORDING_MINUTES, podés usar fallback en build del front:
# VITE_MAX_RECORDING_MINUTES=5

# Desarrollo local (Express): copiá este archivo a .env
# Azure Static Web Apps (Environment variables / Application settings):
#   OPENAI_API_KEY, JWT_SECRET, INITIAL_ADMIN_EMAIL, INITIAL_ADMIN_PASSWORD
#   MAX_RECORDING_MINUTES = minutos máx. por grabación (ej. 5)
#   AZURE_STORAGE_CONNECTION_STRING = connection string de Storage Account (Access keys).
#   (No uses AzureWebJobsStorage en el portal de SWA: suele estar prohibido / reservado.)
